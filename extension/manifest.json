{
  "manifest_version": 3,
  "name": "Agentic Set-of-Mark Extension",
  "version": "1.0",
  "description": "Applies Set-of-Mark visual tags and communicates with the Agent Backend",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
